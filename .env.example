# Copy this file to .env.local and add your Anthropic API key.
# Get a key at https://console.anthropic.com/settings/keys
#
# NOTE: Vite exposes any variable prefixed with VITE_ to the browser bundle.
# This means the key is visible to anyone using the deployed app. For a real
# production deployment, proxy the Anthropic call through a serverless function
# instead of calling the API directly from the browser. See README.md.
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
